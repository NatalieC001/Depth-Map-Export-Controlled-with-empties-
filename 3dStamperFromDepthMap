import bpy

class VIEW3D_PT_depth_map_stamp(bpy.types.Panel):
    bl_label = "Depth Map Stamper"
    bl_idname = "VIEW3D_PT_depth_map_stamp"
    bl_space_type = 'VIEW_3D'
    bl_region_type = 'UI'
    bl_category = 'Depth Map'

    def draw(self, context):
        layout = self.layout
        scene = context.scene

        layout.label(text="Texture Settings:")
        layout.template_ID(scene, "depth_texture_ptr", new="texture.new", open="image.open")
        
        layout.prop(scene, "depth_tiling", text="Enable Tiling")
        layout.prop(scene, "depth_strength", text="Displace Strength")
        
        layout.separator()

        box = layout.box()
        if not scene.depth_tiling:
            box.label(text="Single Image Mode", icon='INFO')
            box.label(text="Uses existing UV layout.")
        else:
            box.label(text="Tiling Mode", icon='TEXTURE_DATA')
            box.label(text="Texture will repeat across UVs.")
        
        layout.separator()
        layout.operator("object.setup_relief_workflow", text="Generate/Update Relief")

class OBJECT_OT_setup_relief_workflow(bpy.types.Operator):
    bl_idname = "object.setup_relief_workflow"
    bl_label = "Setup Relief Workflow"
    bl_options = {'REGISTER', 'UNDO'}

    def execute(self, context):
        obj = context.active_object
        scene = context.scene
        
        if not obj or obj.type != 'MESH':
            self.report({'ERROR'}, "Select a mesh object.")
            return {'CANCELLED'}

        # Ensure UVs exist
        if not obj.data.uv_layers:
            self.report({'ERROR'}, "Mesh has no UV map. Please unwrap first.")
            return {'CANCELLED'}

        # Apply scale to ensure displacement units are correct
        bpy.ops.object.transform_apply(location=False, rotation=False, scale=True)

        # 1. Handle Multires
        m_res = obj.modifiers.get("Relief_Multires")
        if not m_res:
            m_res = obj.modifiers.new(name="Relief_Multires", type='MULTIRES')
            # Subdivide a few times for detail
            for i in range(4):
                bpy.ops.object.multires_subdivide(modifier=m_res.name)

        # 2. Handle Displace
        disp = obj.modifiers.get("Relief_Displace")
        if not disp:
            disp = obj.modifiers.new(name="Relief_Displace", type='DISPLACE')
        
        disp.texture_coords = 'UV'
        disp.direction = 'NORMAL'
        # Adjusting midlevel: 0.5 is usually best for depth maps (gray = no move)
        disp.mid_level = 0.5
        disp.strength = scene.depth_strength

        # 3. Handle Texture
        tex = scene.depth_texture_ptr
        if tex:
            disp.texture = tex
            # Toggle repeat based on UI
            tex.extension = 'REPEAT' if scene.depth_tiling else 'EXTEND'
            self.report({'INFO'}, "Relief Updated.")
        else:
            self.report({'WARNING'}, "No texture assigned.")

        return {'FINISHED'}

# Registration remains the same...
def register():
    bpy.utils.register_class(VIEW3D_PT_depth_map_stamp)
    bpy.utils.register_class(OBJECT_OT_setup_relief_workflow)
    bpy.types.Scene.depth_texture_ptr = bpy.props.PointerProperty(type=bpy.types.Texture)
    bpy.types.Scene.depth_tiling = bpy.props.BoolProperty(name="Tiling", default=False)
    bpy.types.Scene.depth_strength = bpy.props.FloatProperty(name="Strength", default=0.05)

def unregister():
    bpy.utils.unregister_class(VIEW3D_PT_depth_map_stamp)
    bpy.utils.unregister_class(OBJECT_OT_setup_relief_workflow)
    del bpy.types.Scene.depth_texture_ptr
    del bpy.types.Scene.depth_tiling
    del bpy.types.Scene.depth_strength

if __name__ == "__main__":
    register()
