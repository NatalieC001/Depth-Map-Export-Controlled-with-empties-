import bpy

class VIEW3D_PT_depth_map_placer(bpy.types.Panel):
    bl_label = "Depth Map Placer"
    bl_idname = "VIEW3D_PT_depth_map_placer"
    bl_space_type = 'VIEW_3D'
    bl_region_type = 'UI'
    bl_category = 'Depth Map'

    def draw(self, context):
        layout = self.layout
        scene = context.scene

        layout.label(text="Texture Settings:")
        layout.template_ID(scene, "depth_texture_ptr", new="texture.new", open="image.open")
        
        layout.prop(scene, "depth_tiling", text="Enable Tiling")
        layout.prop(scene, "depth_strength", text="Displace Strength")
        
        layout.separator()

        # Conditional Info Box
        if not scene.depth_tiling:
            box = layout.box()
            box.label(text="Single Image Mode:", icon='INFO')
            box.label(text="Ensure UV Islands are overlaid")
            box.label(text="manually for repeated parts.")
            layout.separator()
        
        layout.operator("object.setup_relief_workflow", text="Generate Relief")

class OBJECT_OT_setup_relief_workflow(bpy.types.Operator):
    bl_idname = "object.setup_relief_workflow"
    bl_label = "Setup Relief Workflow"
    bl_options = {'REGISTER', 'UNDO'}

    def execute(self, context):
        obj = context.active_object
        scene = context.scene
        
        if not obj or obj.type != 'MESH':
            self.report({'ERROR'}, "Select a mesh object.")
            return {'CANCELLED'}

        if "Relief_Multires" in obj.modifiers or "Relief_Displace" in obj.modifiers:
            self.report({'WARNING'}, "Modifiers already present.")
            return {'CANCELLED'}

        # Apply scale
        bpy.ops.object.transform_apply(location=False, rotation=False, scale=True)

        # UV Setup Logic
        # If Tiling is ON: We Reset UVs to stack everything perfectly 0-1
        # If Tiling is OFF: We keep existing UVs but warn the user to overlay them
        if scene.depth_tiling:
            bpy.ops.object.mode_set(mode='EDIT')
            bpy.ops.mesh.select_all(action='SELECT')
            bpy.ops.uv.reset()
            bpy.ops.object.mode_set(mode='OBJECT')
        else:
            if not obj.data.uv_layers:
                self.report({'ERROR'}, "Mesh lacks UV Map for single image.")
                return {'CANCELLED'}

        # Modifiers
        m_res = obj.modifiers.new(name="Relief_Multires", type='MULTIRES')
        for i in range(5):
            bpy.ops.object.multires_subdivide(modifier=m_res.name)

        disp = obj.modifiers.new(name="Relief_Displace", type='DISPLACE')
        disp.texture_coords = 'UV'
        disp.direction = 'NORMAL'
        disp.mid_level = 0.5 if not scene.depth_tiling else 0.0
        disp.strength = scene.depth_strength

        tex = scene.depth_texture_ptr
        if tex:
            disp.texture = tex
            if scene.depth_tiling:
                tex.extension = 'REPEAT'
            else:
                tex.extension = 'EXTEND'
            
            self.report({'INFO'}, "Relief Generated.")
        else:
            self.report({'WARNING'}, "Texture missing.")

        return {'FINISHED'}

def register():
    bpy.utils.register_class(VIEW3D_PT_depth_map_placer)
    bpy.utils.register_class(OBJECT_OT_setup_relief_workflow)
    bpy.types.Scene.depth_texture_ptr = bpy.props.PointerProperty(type=bpy.types.Texture)
    bpy.types.Scene.depth_tiling = bpy.props.BoolProperty(name="Tiling", default=False)
    bpy.types.Scene.depth_strength = bpy.props.FloatProperty(name="Strength", default=0.05, min=-2.0, max=2.0)

def unregister():
    bpy.utils.unregister_class(VIEW3D_PT_depth_map_placer)
    bpy.utils.unregister_class(OBJECT_OT_setup_relief_workflow)
    del bpy.types.Scene.depth_texture_ptr
    del bpy.types.Scene.depth_tiling
    del bpy.types.Scene.depth_strength

if __name__ == "__main__":
    register()
